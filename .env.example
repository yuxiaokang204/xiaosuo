# 小说创作Agent系统 - 环境变量配置示例
# 复制此文件为 .env 并填入真实值

# 数据库配置（本地开发默认为SQLite，无需修改即可使用）
DATABASE_URL=sqlite+aiosqlite:///./novel_agent.db

# LLM API配置（可选 - 如使用云端大模型则填入）
# GITHUB_TOKEN=ghp_your_github_token_here
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# 应用配置
APP_NAME=小说创作Agent系统
APP_ENV=development
DEBUG=true

# 内存/上下文配置
MAX_CONTEXT_TOKENS=128000

# 认证配置（可选 - 仅部署服务时需要）
# API_SECRET=your-secret-key-for-api
# JWT_SECRET=your-jwt-secret-key

# 日志配置
LOG_LEVEL=info

